    },
    "backgroundImage": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "gates": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::gate.gate"
    }
  }
