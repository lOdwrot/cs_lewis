{
  "kind": "singleType",
  "collectionName": "home_pages",
  "info": {
    "singularName": "home-page",
    "pluralName": "home-pages",
    "displayName": "Home Page",
    "description": "Editable content for the public home page"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "subtitle": {
      "type": "text"
    },
    "content": {
      "type": "text"
    },
    "backgroundImage": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "ctaLabel": {
      "type": "string"
    },
    "newsButtonLabel": {
      "type": "string"
    },
    "gatesSectionTitle": {
      "type": "string"
    },
    "newsSectionTitle": {
      "type": "string"
    },
    "gates": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::gate.gate"
    },
    "news": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::news.news"
    }
  }
}
