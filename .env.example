# ── Backend server ──────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=1337

# ── Frontend / proxy ────────────────────────────────────────────────────────
STRAPI_URL=http://localhost:1337
# Leave empty to use Vite proxy. Set to full URL for deployments without Vite.
VITE_STRAPI_URL=
# Set to the frontend origin when deploying frontend and backend as separate services.
# This is added to the CORS allowed origins so the frontend can call the API.
CLIENT_URL=
# This is for SEO
VITE_SITE_URL=

# ── Strapi secrets ──────────────────────────────────────────────────────────
# Generate each with: node -e "console.log(require('crypto').randomBytes(16).toString('base64'))"
APP_KEYS=key1,key2,key3,key4
API_TOKEN_SALT=generateme
ADMIN_JWT_SECRET=generateme
TRANSFER_TOKEN_SALT=generateme
ENCRYPTION_KEY=generateme
JWT_SECRET=generateme

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_CLIENT=sqlite
DATABASE_FILENAME=.tmp/data.db
DATABASE_SSL=false
DATABASE_HOST=
DATABASE_PORT=
DATABASE_NAME=
DATABASE_USERNAME=
DATABASE_PASSWORD=
